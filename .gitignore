# Ignore everything
*

# Except directories, so we can traverse into them to find non-ignored files
!*/

# Except any directories named 'frontend', 'Frontend', or ending in 'frontend' (like flockchain-frontend)
!*frontend*/
!*frontend*/**
!*Frontend*/
!*Frontend*/**

# Un-ignore the backend directory
!backend/
!backend/**

# Un-ignore docker files in root
!docker-compose.yml

# Also keep .gitignore to track it
!.gitignore
!README.md
!LICENSE
